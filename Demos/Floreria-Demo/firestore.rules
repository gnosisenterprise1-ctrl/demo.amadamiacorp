rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reglas estrictas para floreria
    match /orders/{orderId} {
      // 1. Escritura Pública: Cualquier cliente desde Cloudflare puede crear un nuevo pedido
      allow create: if true;
      
      // 2. Administración Segura: Solo usuarios logueados en Firebase Auth desde el panel pueden leer o modificar pedidos
      allow read, update, delete: if request.auth != null;
    }
    
    // Bloquear todo lo demás por seguridad (default)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
